# ==================================================
# 基础配置
# ==================================================

lock_file = "/tmp/smartarchiver.lock"

min_age_minutes = 1440
max_retries = 3
conflict_policy = "overwrite"  # skip | copy | overwrite
remove_empty_dirs = true

log_dir = "./logs"
max_log_files = 30

# ==================================================
# 定时任务配置 (可选)
# ==================================================
# 如果不配置 [schedule] 块，则作为一次性脚本执行
# [schedule]
# mode = "cron"  # 可选 "cron" 或 "interval"
# cron_expr = "0 * * * *"  # cron 模式下的表达式，例如每小时执行一次
# interval_seconds = 3600  # interval 模式下的间隔秒数，任务执行完毕后开始计时

# ==================================================
# 规则配置
# ==================================================

[delete_rules]
global_min_size = "0B"

[delete_rules.extensions]
".tmp" = "ALL"
".log" = "10MB"
".DS_Store" = "ALL"

[keep_rules]
global_min_size = "0B"

[keep_rules.extensions]
".ini" = "ALL"
".jpg" = "50KB"
".wav" = "100KB"

# ==================================================
# 任务列表
# ==================================================

[[tasks]]
source = "./source"
dest = "./dest"
min_age_minutes = 180

# --------------------------------------------------

[[tasks]]
source = "./source-2"
dest = "./dest-2"
min_age_minutes = 180

[tasks.delete_rules]
global_min_size = "1MB"

[tasks.delete_rules.extensions]
".zip" = "ALL"

[tasks.keep_rules]
global_min_size = "10MB"

[tasks.keep_rules.extensions]
".raw" = "ALL"

# --------------------------------------------------
